# Backend API Environment (.env in gramvikash_api/)
# Copy this file to .env and fill in your real values.
# NEVER commit the real .env to git.

# ─── Django ─────────────────────────────────────────────────────
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-django-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database & Cache ────────────────────────────────────────────
DATABASE_URL=postgres://gramvikash_user:your_secure_password@localhost:5432/gramvikash_db
REDIS_URL=redis://localhost:6379/1

# ─── AI ──────────────────────────────────────────────────────────
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# ─── Weather ─────────────────────────────────────────────────────
# https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key

# ─── Agri Market Data ────────────────────────────────────────────
# https://api.data.gov.in/
AGMARKNET_API_KEY=your-agmarknet-api-key

# ─── Firebase Admin SDK ──────────────────────────────────────────
# Download service account JSON from Firebase Console > Project Settings > Service Accounts
FIREBASE_CREDENTIALS_PATH=./firebase_admin_sdk.json

# ─── DigiLocker (Gov Identity) ───────────────────────────────────
# https://developer.digitallocker.gov.in/
DIGILOCKER_CLIENT_ID=your-digilocker-client-id
DIGILOCKER_SECRET=your-digilocker-client-secret

# ─── MSG91 (OTP/SMS) ─────────────────────────────────────────────
# https://msg91.com/
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_TEMPLATE_ID=your-otp-template-id

# ─── Google Maps ─────────────────────────────────────────────────
# https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ─── AWS S3 (Audio Storage) ──────────────────────────────────────
# Create an IAM user with S3 permissions
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_STORAGE_BUCKET_NAME=gramvikash-scans-2026
AWS_S3_REGION_NAME=ap-south-1

# ─── ElevenLabs (TTS, optional) ──────────────────────────────────
ELEVENLABS_API_KEY=your-elevenlabs-api-key
