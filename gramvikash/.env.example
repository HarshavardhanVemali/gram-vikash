# Frontend Expo App Environment (gramvikash/.env)
# Copy this file to .env and fill in your real values.
# NEVER commit the real .env to git.

# ─── Backend API URL ─────────────────────────────────────────────
# For local dev: http://localhost:8000 or http://<your-lan-ip>:8000
# For production: https://api.gramvikash.in
EXPO_PUBLIC_API_URL=http://localhost:8000

# ─── Gemini AI ───────────────────────────────────────────────────
# https://aistudio.google.com/app/apikey
EXPO_PUBLIC_GEMINI_API_KEY=your-gemini-api-key

# ─── Firebase (Client-side) ──────────────────────────────────────
# https://console.firebase.google.com/ > Project Settings > General
EXPO_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:your-app-id
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── MSG91 (OTP Widget) ──────────────────────────────────────────
# https://msg91.com/
EXPO_PUBLIC_MSG91_WIDGET_ID=your-widget-id
EXPO_PUBLIC_MSG91_WIDGET_TOKEN=your-widget-token
EXPO_PUBLIC_MSG91_AUTH_KEY=your-auth-key

# ─── Weather ─────────────────────────────────────────────────────
EXPO_PUBLIC_OPENWEATHER_API_KEY=your-openweathermap-api-key

# ─── Agri Market Data ────────────────────────────────────────────
EXPO_PUBLIC_AGMARKNET_API_KEY=your-agmarknet-api-key
